{
  "name": "videorc",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native recording and livestreaming studio technical spike.",
  "author": "TheOrcDev",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "pnpm --filter @videorc/desktop dev",
    "build": "pnpm --filter @videorc/desktop build",
    "typecheck": "pnpm --filter @videorc/desktop typecheck",
    "ffmpeg:build:macos": "bash scripts/build-ffmpeg-macos.sh",
    "package:backend": "cargo build --release -p videorc-backend",
    "package:desktop": "pnpm package:backend && pnpm ffmpeg:build:macos && pnpm --filter @videorc/desktop package",
    "dist:desktop": "pnpm package:backend && pnpm ffmpeg:build:macos && pnpm --filter @videorc/desktop dist",
    "dist:desktop:signed": "pnpm package:backend && pnpm ffmpeg:build:macos && pnpm --filter @videorc/desktop dist:signed",
    "smoke:dev": "node scripts/smoke-dev-app.mjs",
    "smoke:sources": "node scripts/smoke-source-reconciliation.mjs",
    "smoke:start-labels": "node scripts/smoke-start-labels.mjs",
    "smoke:preview-motion": "node scripts/smoke-preview-motion-app.mjs",
    "smoke:preview-surface": "node scripts/smoke-preview-surface-app.mjs",
    "smoke:preview-performance": "node scripts/smoke-preview-performance-app.mjs",
    "smoke:recording-performance": "node scripts/smoke-recording-performance-app.mjs",
    "smoke:recording-native-preview": "node scripts/smoke-recording-native-preview-app.mjs",
    "smoke:streaming-secrets": "node scripts/smoke-streaming-secrets.mjs",
    "smoke:platform-lifecycle": "node scripts/smoke-platform-lifecycle.mjs",
    "smoke:provider-readiness": "node scripts/smoke-provider-readiness.mjs",
    "smoke:provider-readiness:evidence": "node scripts/smoke-provider-readiness.mjs --markdown",
    "smoke:provider-readiness:strict": "VIDEORC_SMOKE_REQUIRE_PROVIDER_READY=1 node scripts/smoke-provider-readiness.mjs",
    "smoke:oauth-guards": "node scripts/smoke-oauth-guards-app.mjs",
    "smoke:oauth": "node scripts/smoke-oauth-app.mjs",
    "smoke:screens": "node scripts/smoke-screens-app.mjs",
    "smoke:multistream": "node scripts/smoke-multistream-app.mjs",
    "smoke:packaged": "node scripts/smoke-packaged-app.mjs",
    "smoke:packaged:bundled": "VIDEORC_SMOKE_REQUIRE_BUNDLED_FFMPEG=1 node scripts/smoke-packaged-app.mjs",
    "smoke:local-gates": "pnpm typecheck && pnpm build && cargo test -p videorc-backend && cargo clippy -p videorc-backend -- -D warnings && pnpm smoke:oauth && pnpm smoke:oauth-guards && pnpm smoke:sources && pnpm smoke:start-labels && pnpm smoke:streaming-secrets && pnpm smoke:platform-lifecycle && pnpm smoke:screens && pnpm smoke:multistream && pnpm smoke:dev && pnpm smoke:provider-readiness",
    "backend:dev": "cargo run -p videorc-backend",
    "backend:test": "cargo test",
    "backend:fmt": "cargo fmt --check",
    "backend:clippy": "cargo clippy -- -D warnings"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}

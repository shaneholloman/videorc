{
  "name": "videorc",
  "version": "0.9.0",
  "private": true,
  "description": "AI-native recording and livestreaming studio technical spike.",
  "author": "TheOrcDev",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "pnpm --filter @videorc/desktop dev",
    "dev:zerocopy": "VIDEORC_ZEROCOPY_SOURCES=1 pnpm --filter @videorc/desktop dev",
    "build": "pnpm --filter @videorc/desktop build",
    "typecheck": "pnpm --filter @videorc/desktop typecheck",
    "check:windows": "XWIN_ACCEPT_LICENSE=1 PATH=\"/opt/homebrew/opt/llvm/bin:$PATH\" cargo xwin check -p videorc-backend --target x86_64-pc-windows-msvc",
    "lint": "eslint \"apps/desktop/**/*.{ts,tsx}\"",
    "format": "prettier --write \"apps/desktop/**/*.{ts,tsx,css,json,html}\" \"*.{json,js,cjs,mjs}\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"apps/desktop/**/*.{ts,tsx,css,json,html}\" \"*.{json,js,cjs,mjs}\" \".github/workflows/*.yml\"",
    "audit:js": "pnpm audit --prod --audit-level high",
    "audit:rust": "cargo audit --deny warnings",
    "audit:deps": "pnpm audit:js && pnpm audit:rust",
    "ffmpeg:build:macos": "bash scripts/build-ffmpeg-macos.sh",
    "ffmpeg:fetch:windows": "node scripts/fetch-ffmpeg-windows.mjs",
    "package:backend": "cargo build --release -p videorc-backend",
    "package:backend:macos": "cargo build --release -p videorc-backend --bin videorc-backend --bin native_preview_host_helper",
    "package:preflight:macos": "node scripts/preflight-macos-package.mjs",
    "package:preflight:windows": "node scripts/preflight-windows-package.mjs",
    "release:preflight:macos": "node scripts/preflight-macos-release.mjs",
    "release:validate:macos": "node scripts/validate-macos-release-artifact.mjs",
    "package:desktop": "pnpm package:backend:macos && pnpm ffmpeg:build:macos && pnpm package:preflight:macos && pnpm --filter @videorc/desktop package",
    "package:desktop:windows": "pnpm package:backend && pnpm ffmpeg:fetch:windows && pnpm package:preflight:windows && pnpm --filter @videorc/desktop package",
    "dist:desktop:windows": "pnpm package:backend && pnpm ffmpeg:fetch:windows && pnpm package:preflight:windows && pnpm --filter @videorc/desktop dist",
    "dist:desktop": "pnpm package:backend:macos && pnpm ffmpeg:build:macos && pnpm package:preflight:macos && pnpm --filter @videorc/desktop dist",
    "dist:desktop:signed": "pnpm release:preflight:macos && pnpm package:backend:macos && pnpm ffmpeg:build:macos && pnpm package:preflight:macos && pnpm --filter @videorc/desktop dist:signed",
    "analyze:recording": "node scripts/analyze-recording.mjs",
    "analyze:startup": "node scripts/analyze-startup-resolution.mjs",
    "test:analyzer": "node --test scripts/lib/recording-analyzer.test.mjs",
    "test:scripts": "node --test scripts/lib/*.test.mjs",
    "baseline:real-source": "node scripts/real-source-baseline-app.mjs",
    "baseline:real-source:raw-yuv": "VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=raw-yuv420p node scripts/real-source-baseline-app.mjs",
    "baseline:real-source:videotoolbox-output": "VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264 node scripts/real-source-baseline-app.mjs",
    "baseline:real-source:videotoolbox-mpegts-output": "VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264-mpegts node scripts/real-source-baseline-app.mjs",
    "baseline:real-source:motion-mpegts-output": "VIDEORC_BASELINE_SCREEN_MOTION_STIMULUS=1 VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264-mpegts node scripts/real-source-baseline-app.mjs",
    "baseline:real-source:4k30": "VIDEORC_BASELINE_WIDTH=3840 VIDEORC_BASELINE_HEIGHT=2160 VIDEORC_BASELINE_FPS=30 VIDEORC_BASELINE_BITRATE_KBPS=30000 VIDEORC_BASELINE_SCREEN_MOTION_STIMULUS=1 node scripts/real-source-baseline-app.mjs",
    "baseline:real-source:4k30:av-sync": "VIDEORC_BASELINE_WIDTH=3840 VIDEORC_BASELINE_HEIGHT=2160 VIDEORC_BASELINE_FPS=30 VIDEORC_BASELINE_BITRATE_KBPS=30000 VIDEORC_BASELINE_AV_SYNC_STIMULUS=1 VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264-mpegts node scripts/real-source-baseline-app.mjs",
    "baseline:real-source:4k30:endurance": "VIDEORC_BASELINE_WIDTH=3840 VIDEORC_BASELINE_HEIGHT=2160 VIDEORC_BASELINE_FPS=30 VIDEORC_BASELINE_BITRATE_KBPS=30000 VIDEORC_BASELINE_SCREEN_MOTION_STIMULUS=1 VIDEORC_BASELINE_RECORDING_MS=600000 VIDEORC_SMOKE_TIMEOUT_MS=900000 node scripts/real-source-baseline-app.mjs",
    "baseline:evidence:4k30": "node scripts/check-real-source-evidence.mjs --require-motion --min-recording-ms=60000",
    "baseline:evidence:4k30:endurance": "node scripts/check-real-source-evidence.mjs --require-motion --min-recording-ms=600000",
    "baseline:real-source:av-sync-mpegts-output": "VIDEORC_BASELINE_AV_SYNC_STIMULUS=1 VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264-mpegts node scripts/real-source-baseline-app.mjs",
    "baseline:stream:av-sync": "VIDEORC_PREMIUM_FEATURES=1 node scripts/stream-av-sync-baseline.mjs",
    "baseline:stream:av-sync:endurance": "VIDEORC_PREMIUM_FEATURES=1 VIDEORC_BASELINE_RECORDING_MS=600000 VIDEORC_SMOKE_TIMEOUT_MS=900000 node scripts/stream-av-sync-baseline.mjs",
    "baseline:stream:split-output-4k-record": "VIDEORC_PREMIUM_FEATURES=1 node scripts/stream-av-sync-baseline.mjs --gate --skip-record-only --require-split-output-4k-record",
    "baseline:stream:youtube-4k30": "VIDEORC_PREMIUM_FEATURES=1 node scripts/stream-av-sync-baseline.mjs --gate --skip-record-only --require-youtube-4k-stream",
    "baseline:stream:youtube-4k30:mixed": "VIDEORC_PREMIUM_FEATURES=1 node scripts/stream-av-sync-baseline.mjs --gate --skip-record-only --require-mixed-youtube-4k-twitch-1080p",
    "baseline:real-source:camera-mpegts-output": "VIDEORC_BASELINE_NO_SCREEN=1 VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264-mpegts node scripts/real-source-baseline-app.mjs",
    "baseline:real-source:camera-mpegts-output:no-preview": "VIDEORC_BASELINE_NO_SCREEN=1 VIDEORC_BASELINE_NO_PREVIEW_SURFACE=1 VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264-mpegts node scripts/real-source-baseline-app.mjs",
    "acceptance:obs-side-by-side": "node scripts/obs-side-by-side-acceptance.mjs",
    "measure:av-sync": "node scripts/measure-av-sync.mjs",
    "smoke:dev": "node scripts/smoke-dev-app.mjs",
    "smoke:backend-single-instance": "node scripts/smoke-backend-single-instance.mjs",
    "smoke:process-lifecycle": "node scripts/smoke-process-lifecycle.mjs",
    "smoke:process-memory": "node scripts/smoke-process-memory.mjs",
    "smoke:sources": "node scripts/smoke-source-reconciliation.mjs",
    "smoke:start-labels": "node scripts/smoke-start-labels.mjs",
    "smoke:preview-motion": "node scripts/smoke-preview-motion-app.mjs",
    "probe:preview-window": "node scripts/preview-window-probe.mjs",
    "probe:preview-lifecycle": "node scripts/preview-lifecycle-probe.mjs",
    "smoke:preview-surface": "node scripts/smoke-preview-surface-app.mjs",
    "smoke:preview-endurance": "VIDEORC_SMOKE_TIMEOUT_MS=720000 VIDEORC_PREVIEW_SURFACE_SAMPLE_MS=600000 node scripts/smoke-preview-surface-app.mjs",
    "smoke:preview-performance": "node scripts/smoke-preview-performance-app.mjs",
    "smoke:recording-performance": "node scripts/smoke-recording-performance-app.mjs",
    "smoke:recording-studio": "node scripts/smoke-recording-studio.mjs",
    "smoke:recording-studio:devices": "VIDEORC_RECORDING_STUDIO_DEVICE_SMOKE=1 node scripts/smoke-recording-studio.mjs",
    "smoke:screen-recording-real": "VIDEORC_BASELINE_RECORDING_MS=8000 VIDEORC_BASELINE_WARMUP_MS=2000 VIDEORC_BASELINE_PREVIEW_MEASUREMENT_MS=2000 VIDEORC_BASELINE_NO_CAMERA=1 VIDEORC_BASELINE_NO_MIC=1 VIDEORC_BASELINE_LAYOUT_PRESET=screen-only VIDEORC_BASELINE_SCREEN_MOTION_STIMULUS=1 node scripts/real-source-baseline-app.mjs --screen-recording-gate",
    "smoke:notes-window-invisible": "VIDEORC_NOTES_WINDOW=1 VIDEORC_BASELINE_NOTES_OVERLAY=1 VIDEORC_BASELINE_RECORDING_MS=8000 VIDEORC_BASELINE_WARMUP_MS=2000 VIDEORC_BASELINE_PREVIEW_MEASUREMENT_MS=2000 VIDEORC_BASELINE_NO_CAMERA=1 VIDEORC_BASELINE_NO_MIC=1 VIDEORC_BASELINE_LAYOUT_PRESET=screen-only VIDEORC_BASELINE_SCREEN_MOTION_STIMULUS=1 node scripts/real-source-baseline-app.mjs --notes-overlay-gate",
    "smoke:recording-native-preview": "node scripts/smoke-recording-native-preview-app.mjs",
    "smoke:recording-native-preview:hidden": "VIDEORC_SMOKE_TIMEOUT_MS=180000 VIDEORC_NATIVE_PREVIEW_INCLUDE_HIDDEN=1 node scripts/smoke-recording-native-preview-app.mjs",
    "smoke:recording-native-preview:endurance": "VIDEORC_SMOKE_TIMEOUT_MS=240000 VIDEORC_NATIVE_PREVIEW_RECORDING_MS=60000 VIDEORC_NATIVE_PREVIEW_WARMUP_MS=12000 VIDEORC_NATIVE_PREVIEW_INCLUDE_1440=1 VIDEORC_NATIVE_PREVIEW_LAYOUT_STRESS_UPDATES=12 node scripts/smoke-recording-native-preview-app.mjs",
    "probe:recording-native-preview:videotoolbox": "VIDEORC_NATIVE_PREVIEW_SOURCE_COMPLETE_SCENE=1 VIDEORC_ENCODER_BRIDGE_VIDEOTOOLBOX_PROBE=1 VIDEORC_NATIVE_PREVIEW_REPORT_ONLY=1 VIDEORC_NATIVE_PREVIEW_RECORDING_MS=6000 VIDEORC_NATIVE_PREVIEW_WARMUP_MS=1500 VIDEORC_NATIVE_PREVIEW_MEASUREMENT_MS=2500 node scripts/smoke-recording-native-preview-app.mjs",
    "probe:recording-native-preview:videotoolbox-output": "VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264 pnpm probe:recording-native-preview:videotoolbox",
    "probe:recording-native-preview:videotoolbox-mpegts-output": "VIDEORC_ENCODER_BRIDGE_VIDEO_OUTPUT=videotoolbox-h264-mpegts pnpm probe:recording-native-preview:videotoolbox",
    "smoke:encoder-bridge": "node scripts/smoke-encoder-bridge-app.mjs",
    "smoke:streaming-secrets": "node scripts/smoke-streaming-secrets.mjs",
    "smoke:platform-lifecycle": "node scripts/smoke-platform-lifecycle.mjs",
    "smoke:provider-readiness": "node scripts/smoke-provider-readiness.mjs",
    "smoke:provider-readiness:evidence": "node scripts/smoke-provider-readiness.mjs --markdown",
    "smoke:provider-readiness:strict": "VIDEORC_SMOKE_REQUIRE_PROVIDER_READY=1 node scripts/smoke-provider-readiness.mjs",
    "support-bundle:verify": "node scripts/verify-support-bundle.mjs",
    "smoke:oauth-guards": "node scripts/smoke-oauth-guards-app.mjs",
    "smoke:live-chat-fake-providers": "node scripts/smoke-live-chat-fake-providers.mjs",
    "smoke:oauth": "node scripts/smoke-oauth-app.mjs",
    "smoke:screens": "node scripts/smoke-screens-app.mjs",
    "smoke:multistream": "VIDEORC_PREMIUM_FEATURES=1 node scripts/smoke-multistream-app.mjs",
    "smoke:packaged": "node scripts/smoke-packaged-app.mjs",
    "smoke:packaged:bundled": "VIDEORC_SMOKE_REQUIRE_BUNDLED_FFMPEG=1 node scripts/smoke-packaged-app.mjs",
    "smoke:packaged:native-preview": "VIDEORC_SMOKE_PACKAGED_APP=1 VIDEORC_EXPECT_NATIVE_METAL_PREVIEW=1 node scripts/smoke-preview-surface-app.mjs",
    "smoke:packaged:release": "pnpm smoke:packaged:bundled && pnpm smoke:packaged:native-preview",
    "smoke:local-gates:windows": "node scripts/smoke-local-gates-windows.mjs",
    "smoke:local-gates": "pnpm typecheck && pnpm build && cargo test -p videorc-backend && cargo clippy -p videorc-backend -- -D warnings && pnpm smoke:oauth && pnpm smoke:oauth-guards && pnpm smoke:sources && pnpm smoke:start-labels && pnpm smoke:streaming-secrets && pnpm smoke:platform-lifecycle && pnpm smoke:screens && pnpm smoke:multistream && pnpm smoke:dev && pnpm smoke:provider-readiness",
    "backend:dev": "cargo run -p videorc-backend --bin videorc-backend",
    "backend:test": "cargo test",
    "backend:fmt": "cargo fmt --check",
    "backend:clippy": "cargo clippy -- -D warnings"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  }
}

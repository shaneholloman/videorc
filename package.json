{
  "name": "videogre",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native recording and livestreaming studio technical spike.",
  "author": "TheOrcDev",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "pnpm --filter @videogre/desktop dev",
    "build": "pnpm --filter @videogre/desktop build",
    "typecheck": "pnpm --filter @videogre/desktop typecheck",
    "package:backend": "cargo build --release -p videogre-backend",
    "package:desktop": "pnpm package:backend && pnpm --filter @videogre/desktop package",
    "dist:desktop": "pnpm package:backend && pnpm --filter @videogre/desktop dist",
    "backend:dev": "cargo run -p videogre-backend",
    "backend:test": "cargo test",
    "backend:fmt": "cargo fmt --check",
    "backend:clippy": "cargo clippy -- -D warnings"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
